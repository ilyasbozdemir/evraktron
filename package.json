{
  "name": "evraktron",
  "version": "1.0.0",
  "description": "Portable evrak yönetim sistemi - .evrak dosya formatı desteğiyle",
  "main": "out/main/main.js",
  "homepage": "./",
  "author": "İlyas Bozdemir",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite",
    "build": "electron-vite build && electron-builder",
    "build:win": "electron-vite build && electron-builder --win portable",
    "build:linux": "electron-vite build && electron-builder --linux AppImage",
    "build:mac": "electron-vite build && electron-builder --mac dmg",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^9.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.378.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.3.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ilyasbozdemir.evraktron",
    "productName": "Evraktron",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "fileAssociations": [
        {
          "ext": "evrak",
          "name": "Evraktron Dosyası",
          "description": "Evraktron evrak dosyası",
          "icon": "public/icon.png",
          "role": "Editor"
        }
      ]
    },
    "linux": {
      "target": "AppImage",
      "fileAssociations": [
        {
          "ext": "evrak",
          "name": "Evraktron Dosyası"
        }
      ]
    },
    "mac": {
      "target": "dmg",
      "fileAssociations": [
        {
          "ext": "evrak",
          "name": "Evraktron Dosyası",
          "role": "Editor"
        }
      ]
    },
    "portable": {
      "artifactName": "Evraktron-Portable-${version}.exe"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
}