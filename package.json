{
  "name": "evraktron",
  "version": "1.1.1",
  "description": "Portable evrak yönetim sistemi - .etap dosya formatı desteğiyle",
  "main": "out/main/main.js",
  "homepage": "./",
  "author": "İlyas Bozdemir",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite",
    "build": "electron-vite build && electron-builder --config electron-builder.config.cjs",
    "build:win": "electron-vite build && electron-builder --win --config electron-builder.config.cjs",
    "build:linux": "electron-vite build && electron-builder --linux AppImage --config electron-builder.config.cjs",
    "build:mac": "electron-vite build && electron-builder --mac dmg --config electron-builder.config.cjs",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-virtual": "^3.13.25",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^9.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.378.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.3.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@jimp/plugin-resize": "^1.6.1",
    "@types/adm-zip": "^0.5.5",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  }
